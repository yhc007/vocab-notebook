# CoreDB HTTP /query 엔드포인트 (host:port 또는 전체 URL)
COREDB_NODE=127.0.0.1:9142

# Claude API
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
# 단어 뜻(definition) 정제 패스(Stage 2). 1이면 추출 후 청크당 +1 호출로
# definition을 문맥 기준으로 한 번 더 교정한다. 비용이 늘어 기본은 off.
EXTRACT_REFINE=

# ElevenLabs TTS(기사 읽어주기). 키가 있으면 기사 페이지에 '읽어주기' 버튼이 뜬다.
# 없으면 기능 비활성. 음성 기본=Rachel(미국식 여성), 모델 기본=eleven_flash_v2_5(저렴).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=
# 생성된 mp3 캐시 디렉터리(재생 재과금 방지). 기본 ./tts-cache
TTS_CACHE_DIR=

# 서버
BIND_ADDR=0.0.0.0:8080

# Google OAuth 로그인 게이트
# GOOGLE_CLIENT_ID 가 있고 AUTH_DISABLED 가 꺼져 있으면 인증이 활성화된다.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Google OAuth 클라이언트에 등록한 redirect URI 와 정확히 일치해야 한다.
# 로컬 테스트 예: http://localhost:8080/auth/callback
OAUTH_REDIRECT_URL=https://your-domain/auth/callback
# 허용 이메일(쉼표로 여러 개) 또는 허용 호스티드 도메인(hd). 둘 중 하나만 만족하면 통과.
ALLOWED_EMAIL=paul.yu@coreon.ai
ALLOWED_HD=coreon.ai

# 세션 쿠키 암호화 키의 시드(SHA-512로 64바이트 유도). 미설정 시 재시작마다 로그인 풀림.
SESSION_SECRET=
# 로컬/개발에서 Google 자격증명 없이 게이트를 끄려면 1 (프로덕션에선 절대 설정 금지)
AUTH_DISABLED=
